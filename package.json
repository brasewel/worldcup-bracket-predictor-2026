{
  "name": "worldcup-bracket",
  "version": "1.0.0",
  "description": "FIFA World Cup 2026 bracket prediction app",
  "main": "src/index.ts",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:migrate:local": "wrangler d1 execute worldcup-bracket-db --local --file=schema.sql",
    "db:migrate:remote": "wrangler d1 execute worldcup-bracket-db --remote --file=schema.sql"
  },
  "devDependencies": {
    "wrangler": "^3.0.0",
    "@cloudflare/workers-types": "^4.0.0",
    "typescript": "^5.0.0"
  }
}
